                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'local') {",
                  "  pm.test('Real service responds under 50ms SLA threshold', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(50);",
                  "  });",
                  "} else {",
                  "  pm.test('Skipped on mock environment: mock server latency is not reliable evidence', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
