            "url": {
              "raw": "{{baseUrl}}/access/check",
              "host": ["{{baseUrl}}"],
              "path": ["access", "check"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2cafe\",\n  \"gateId\": \"GATE-01\",\n  \"direction\": \"IN\",\n  \"timestamp\": \"2026-06-01T10:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Gửi thiếu trường bắt buộc cardId. Mong đợi lỗi 400 hoặc 422."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid payload returns client error status', function () {",
                  "  pm.expect([400, 422]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Error response matches RFC 7807 ProblemDetails', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('type');",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(json.status).to.be.within(400, 599);",
                  "});"
                ]
              }
            }
          ]
        },
