            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2cafe\",\n  \"cardId\": \"CARD-123456\",\n  \"gateId\": \"GATE-01\",\n  \"direction\": \"IN\",\n  \"timestamp\": \"2026-06-01T10:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Gửi token sai định dạng, mong đợi 401 hoặc 403 trên service thật."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token needs real backend validation', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
