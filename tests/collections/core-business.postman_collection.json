            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2cafe\",\n  \"cardId\": \"CARD-123456\",\n  \"gateId\": \"GATE-01\",\n  \"direction\": \"IN\",\n  \"timestamp\": \"2026-06-01T10:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Kiểm thử Auth thật: khi thiếu token, service thật phải trả 401 hoặc 403. Skip trên mock vì Prism không validate auth thật."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 or 403', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /access/check - invalid token is rejected on real service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
